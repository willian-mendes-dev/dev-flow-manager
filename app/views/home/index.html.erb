<section>
  <% if @view == "dashboard" %>
    <div class="mb-10 grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-4">
      <div class="rounded-2xl border border-gray-100 bg-white p-6 shadow-sm transition hover:shadow-md">
        <div class="mb-4 flex items-center justify-between">
          <div class="flex items-center justify-center rounded-xl bg-indigo-50 p-3 text-indigo-600">
            <svg width="48" height="48" class="h-12 w-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
          </div>
          <span class="text-xs font-bold uppercase text-green-500">Atualizado em tempo real</span>
        </div>
        <h3 class="text-sm font-medium text-slate-500">Produtos Cadastrados</h3>
        <p class="mt-1 text-3xl font-bold text-slate-800"><%= @total_products %></p>
      </div>

      <div class="rounded-2xl border border-gray-100 bg-white p-6 shadow-sm transition hover:shadow-md">
        <div class="mb-4 flex items-center justify-between">
          <div class="flex items-center justify-center rounded-xl bg-red-50 p-3 text-red-600">
            <svg width="48" height="48" class="h-12 w-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
          </div>
          <span class="text-xs font-bold uppercase text-red-500">Acompanhamento</span>
        </div>
        <h3 class="text-sm font-medium text-slate-500">Estoque Baixo</h3>
        <p class="mt-1 text-3xl font-bold text-slate-800"><%= @low_stock_count %></p>
      </div>

      <div class="rounded-2xl border border-gray-100 bg-white p-6 shadow-sm transition hover:shadow-md">
        <div class="mb-4 flex items-center justify-between">
          <div class="flex items-center justify-center rounded-xl bg-green-50 p-3 text-green-600">
            <svg width="48" height="48" class="h-12 w-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path></svg>
          </div>
          <span class="text-xs font-bold uppercase text-slate-400">Produtos zerados</span>
        </div>
        <h3 class="text-sm font-medium text-slate-500">Sem Estoque</h3>
        <p class="mt-1 text-3xl font-bold text-slate-800"><%= @out_of_stock_count %></p>
      </div>

      <div class="rounded-2xl border border-gray-100 bg-white p-6 shadow-sm transition hover:shadow-md">
        <div class="mb-4 flex items-center justify-between">
          <div class="flex items-center justify-center rounded-xl bg-amber-50 p-3 text-amber-600">
            <svg width="48" height="48" class="h-12 w-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.333 0-2 .667-2 2s.667 2 2 2 2 .667 2 2-.667 2-2 2m0-10V6m0 12v-2m9-4a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <span class="text-xs font-bold uppercase text-amber-500">Dashboard inteligente</span>
        </div>
        <h3 class="text-sm font-medium text-slate-500">Valor Total do Estoque</h3>
        <p class="mt-1 text-3xl font-bold text-slate-800">
          <%= number_to_currency(@total_inventory_value, unit: "R$ ", separator: ",", delimiter: ".") %>
        </p>
      </div>
    </div>

    <div class="mb-6 rounded-2xl border border-gray-100 bg-white shadow-sm">
      <div class="flex items-center justify-between border-b border-gray-50 p-6">
        <h3 class="text-lg font-bold text-slate-800">Conselheiro Financeiro com IA</h3>
        <span class="text-xs font-semibold uppercase tracking-wide text-indigo-500">Gemini Advisor</span>
      </div>
      <div class="p-6">
        <% if @ai_insight.present? %>
          <div class="rounded-xl border border-indigo-100 bg-indigo-50 p-5 text-indigo-900">
            <div class="mb-3 flex items-center gap-2">
              <span class="text-xl">💡</span>
              <p class="text-sm font-semibold uppercase tracking-wide text-indigo-700">Diagnóstico da IA</p>
            </div>
            <div class="text-sm leading-6"><%= format_ai_text(@ai_insight) %></div>
            <div class="mt-4 flex items-center justify-between gap-3">
              <p class="text-xs text-indigo-700">
                Atualizado em:
                <%= @ai_insight_generated_at&.strftime("%d/%m/%Y %H:%M") || "agora" %>
              </p>
              <%= button_to "Atualizar Análise", generate_home_insights_path, method: :post, class: "rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-indigo-700" %>
            </div>
          </div>
        <% else %>
          <div class="flex flex-col items-start gap-3">
            <p class="text-sm text-slate-600">
              Gere um diagnóstico financeiro rápido com base na situação atual do estoque.
            </p>
            <%= button_to "✨ Analisar Saúde do Estoque com IA", generate_home_insights_path, method: :post, class: "rounded-lg bg-indigo-600 px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-indigo-700" %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="mb-6 rounded-2xl border border-gray-100 bg-white shadow-sm">
      <div class="flex items-center justify-between border-b border-gray-50 p-6">
        <h3 class="text-lg font-bold text-slate-800">Atividades Recentes</h3>
        <span class="text-xs font-semibold uppercase tracking-wide text-slate-500">Criacao e edicao de produtos</span>
      </div>
      <div class="divide-y divide-gray-100">
        <% @recent_activities.each do |activity| %>
          <div class="flex flex-col gap-1 px-6 py-4 text-sm text-slate-700 md:flex-row md:items-center md:justify-between">
            <p><%= activity.description %></p>
            <span class="text-xs font-medium text-slate-500">
              <%= activity.user&.name.presence || "Sistema" %> ·
              <%= activity.created_at.strftime("%d/%m/%Y %H:%M") %>
            </span>
          </div>
        <% end %>
        <% if @recent_activities.empty? %>
          <div class="px-6 py-6 text-center text-sm text-slate-500">
            Nenhuma atividade recente. Crie ou edite um produto para registrar historico.
          </div>
        <% end %>
      </div>
    </div>

    <div class="mb-6 grid grid-cols-1 gap-6 xl:grid-cols-2">
      <div class="rounded-2xl border border-gray-100 bg-white shadow-sm">
        <div class="flex items-center justify-between border-b border-gray-50 p-6">
          <h3 class="text-lg font-bold text-slate-800">Distribuição Financeira por Categoria</h3>
          <span class="text-xs font-semibold uppercase tracking-wide text-slate-500">Valor total por grupo</span>
        </div>
        <div class="p-6">
          <div class="mx-auto w-full max-w-2xl">
            <% if respond_to?(:pie_chart) %>
              <%= pie_chart @chart_data,
                  height: "340px",
                  donut: true,
                  legend: "bottom",
                  colors: ["#4f46e5", "#ef4444", "#10b981", "#f59e0b", "#64748b"],
                  messages: { empty: "Sem dados suficientes para montar o gráfico." } %>
            <% else %>
              <div class="rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
                Gráfico indisponível no momento. Rode <code>bundle install</code> e reinicie o servidor para habilitar o Chartkick.
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <div class="rounded-2xl border border-gray-100 bg-white shadow-sm">
        <div class="flex items-center justify-between border-b border-gray-50 p-6">
          <h3 class="text-lg font-bold text-slate-800">Top 5 Produtos por Valor em Estoque</h3>
          <span class="text-xs font-semibold uppercase tracking-wide text-slate-500">Maior impacto financeiro</span>
        </div>
        <div class="p-6">
          <% if respond_to?(:bar_chart) %>
            <%= bar_chart @top_products_data,
                prefix: "R$ ",
                xtitle: "Valor em Estoque",
                colors: ["#4f46e5"],
                height: "340px",
                library: { indexAxis: "y" } %>
          <% else %>
            <div class="rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
              Gráfico indisponível no momento. Rode <code>bundle install</code> e reinicie o servidor para habilitar o Chartkick.
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="overflow-hidden rounded-2xl border border-gray-100 bg-white shadow-sm">
      <div class="flex items-center justify-between border-b border-gray-50 p-6">
        <h3 class="text-lg font-bold text-slate-800">Produtos Recentes</h3>
        <%= link_to "Ver todos", products_path, class: "text-sm font-semibold text-indigo-600 hover:underline" %>
      </div>
      <table class="w-full border-collapse text-left">
        <thead>
          <tr class="bg-gray-50 text-xs uppercase tracking-wider text-slate-500">
            <th class="p-4 font-semibold">Produto</th>
            <th class="p-4 font-semibold">SKU</th>
            <th class="p-4 font-semibold">Categoria</th>
            <th class="p-4 text-right font-semibold">Estoque</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 text-sm text-slate-600">
          <% @recent_products.each do |product| %>
            <tr class="transition hover:bg-gray-50">
              <td class="p-4 font-medium text-slate-800"><%= product.name %></td>
              <td class="p-4 font-mono"><%= product.sku %></td>
              <td class="p-4"><%= product.category %></td>
              <td class="p-4 text-right font-mono font-bold"><%= product.stock_quantity %></td>
            </tr>
          <% end %>
          <% if @recent_products.empty? %>
            <tr>
              <td colspan="4" class="p-6 text-center text-slate-500">Nenhum produto cadastrado. Clique em Novo Produto para começar.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% elsif @view == "estoque_baixo" %>
    <div class="overflow-hidden rounded-2xl border border-gray-100 bg-white shadow-sm">
      <div class="flex items-center justify-between border-b border-gray-50 p-6">
        <h3 class="text-lg font-bold text-slate-800">Estoque Baixo</h3>
        <span class="text-sm font-semibold text-red-500">Atencao necessaria</span>
      </div>
      <table class="w-full border-collapse text-left">
        <thead>
          <tr class="bg-gray-50 text-xs uppercase tracking-wider text-slate-500">
            <th class="p-4 font-semibold">SKU</th>
            <th class="p-4 font-semibold">Produto</th>
            <th class="p-4 text-right font-semibold">Estoque Atual</th>
            <th class="p-4 text-right font-semibold">Minimo</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 text-sm text-slate-600">
          <% @low_stock_items.each do |item| %>
            <tr class="transition hover:bg-gray-50">
              <td class="p-4 font-mono"><%= item.sku %></td>
              <td class="p-4 font-medium text-slate-800"><%= item.name %></td>
              <td class="p-4 text-right font-bold text-red-600"><%= item.stock_quantity %></td>
              <td class="p-4 text-right">20</td>
            </tr>
          <% end %>
          <% if @low_stock_items.empty? %>
            <tr>
              <td colspan="4" class="p-6 text-center text-slate-500">Nenhum produto com estoque baixo no momento.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</section>
