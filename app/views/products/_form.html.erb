<%= form_with model: product, local: true, class: "space-y-4" do |f| %>
  <div>
    <%= f.label :name, "Nome", class: "mb-1 block text-sm font-medium text-slate-700" %>
    <%= f.text_field :name, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none" %>
  </div>

  <div>
    <%= f.label :description, "Descricao", class: "mb-1 block text-sm font-medium text-slate-700" %>
    <%= f.text_area :description, rows: 4, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none" %>
  </div>

  <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
    <div>
      <%= f.label :sku, "SKU", class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= f.text_field :sku, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none" %>
    </div>
    <div>
      <%= f.label :category, "Categoria", class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= f.text_field :category, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none" %>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
    <div>
      <%= f.label :price, "Preco", class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= f.number_field :price, step: 0.01, min: 0, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none" %>
    </div>
    <div>
      <%= f.label :stock_quantity, "Quantidade em estoque", class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= f.number_field :stock_quantity, min: 0, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none" %>
    </div>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit class: "rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700" %>
    <%= link_to "Cancelar", products_path, class: "text-sm font-medium text-slate-600 hover:text-slate-800" %>
  </div>
<% end %>
