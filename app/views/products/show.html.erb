<section class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-slate-800"><%= @product.name %></h1>
    <div class="flex items-center gap-3">
      <%= link_to "Editar", edit_product_path(@product), class: "text-sm font-semibold text-indigo-600 hover:underline" %>
      <%= link_to "Voltar", products_path, class: "text-sm font-semibold text-slate-700 hover:underline" %>
    </div>
  </div>

  <div class="rounded-2xl border border-gray-100 bg-white p-6 shadow-sm">
    <dl class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <div>
        <dt class="text-xs uppercase tracking-wider text-slate-500">SKU</dt>
        <dd class="mt-1 text-sm font-medium text-slate-800"><%= @product.sku %></dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wider text-slate-500">Categoria</dt>
        <dd class="mt-1 text-sm font-medium text-slate-800"><%= @product.category %></dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wider text-slate-500">Preco</dt>
        <dd class="mt-1 text-sm font-medium text-slate-800"><%= number_to_currency(@product.price) %></dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wider text-slate-500">Quantidade em estoque</dt>
        <dd class="mt-1 text-sm font-medium text-slate-800"><%= @product.stock_quantity %></dd>
      </div>
      <div class="md:col-span-2">
        <dt class="text-xs uppercase tracking-wider text-slate-500">Descricao</dt>
        <dd class="mt-1 text-sm text-slate-700"><%= @product.description.presence || "-" %></dd>
      </div>
    </dl>
  </div>
</section>
