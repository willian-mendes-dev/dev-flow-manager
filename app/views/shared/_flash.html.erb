<% flash.each do |type, message| %>
  <% next if message.blank? %>
  <% success_flash = type.to_s == "notice" %>
  <% container_classes = success_flash ? "border-green-200 bg-green-50 text-green-800" : "border-red-200 bg-red-50 text-red-800" %>
  <% icon_classes = success_flash ? "text-green-600" : "text-red-600" %>

  <div class="mb-4 flex items-start gap-3 rounded-lg border px-4 py-3 shadow-sm <%= container_classes %>">
    <span class="<%= icon_classes %>">
      <% if success_flash %>
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
      <% else %>
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01m-7.938 4h15.876c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L2.34 17c-.77 1.333.192 3 1.732 3z"></path></svg>
      <% end %>
    </span>
    <p class="text-sm font-medium"><%= message %></p>
  </div>
<% end %>
